---
layout: layouts/base.njk
navKey: home
---
<div class="layout-grid">
    <aside class="identity-rail">
        <div class="identity-block">
            <p class="eyebrow">Personal website</p>
            <h1 class="identity-title">{{ site.name }}</h1>
            <p class="identity-summary">{{ site.tagline }}</p>
        </div>

        <div class="identity-meta">
            {% for fact in site.quickFacts %}
                <span class="meta-pill">{{ fact }}</span>
            {% endfor %}
        </div>
    </aside>

    <main class="content-column">
        <section class="lead-panel">
            <h2 class="lead-title">
                {% for line in site.homeIntroLines %}
                    <span class="lead-line">{{ line }}</span>{% if not loop.last %}<br>{% endif %}
                {% endfor %}
            </h2>
            <p class="lead-copy">{{ site.homeIntroText }}</p>
        </section>

        <section id="posts" class="content-section">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">{{ site.postsIntroTitle }}</p>
                    <h2 class="section-title">Recent writing, sketches, and project notes.</h2>
                </div>
                {% if site.postsIntroText %}
                    <p class="section-description">{{ site.postsIntroText }}</p>
                {% endif %}
            </div>

            <div class="section-footer-link section-footer-link-top no-divider">
                <a href="/posts/" class="browse-link">Browse all posts</a>
            </div>

            <div class="list-stream">
                {% for post in collections.recentPosts %}
                    <article class="stream-item post-item">
                        <div class="stream-copy">
                            <div class="stream-meta">
                                <span class="stream-topic">{{ post.data.type }}</span>
                                <span class="stream-subtopic">{{ post.data.topic }}</span>
                                <span class="stream-date">{{ post.date | displayDate }}</span>
                            </div>
                            <h3 class="stream-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                            <p class="stream-excerpt">{{ post.data.excerpt }}</p>
                            <div class="stream-actions">
                                <a href="{{ post.url }}" class="text-link">Read post</a>
                            </div>
                        </div>
                        <a href="{{ post.url }}" class="stream-preview{% if post.data.imageFit == 'contain' %} stream-preview-contain{% endif %}" aria-label="Open {{ post.data.title }}">
                            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="stream-preview-image">
                        </a>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section id="contact" class="content-section">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Contact</p>
                    <h2 class="section-title">Contact</h2>
                </div>
            </div>

            <div class="contact-panel">
                <p class="contact-copy">{{ site.contact.blurb }}</p>
                <div class="contact-links">
                    {% for link in site.contact.links %}
                        <a href="{{ link.url }}"
                           {% if link.external %}target="_blank" rel="noreferrer"{% endif %}
                           class="contact-link">
                            {{ link.label }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>

        <footer class="site-footer">
            <p>{{ site.footerText }}</p>
            <p>&copy; 2026 {{ site.name }}</p>
        </footer>
    </main>
</div>
