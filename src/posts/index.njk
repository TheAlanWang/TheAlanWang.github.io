---
layout: layouts/base.njk
title: Posts
description: Posts archive for Alan Wang.
navKey: posts
---
<div class="layout-grid">
    <aside class="identity-rail">
        <div class="identity-block">
            <p class="eyebrow">Personal website</p>
            <h1 class="identity-title">{{ site.name }}</h1>
            <p class="identity-summary">{{ site.tagline }}</p>
        </div>

        <div class="identity-meta">
            {% for fact in site.quickFacts %}
                <span class="meta-pill">{{ fact }}</span>
            {% endfor %}
        </div>
    </aside>

    <main class="content-column">
        <section class="lead-panel lead-panel-archive">
            <p class="section-kicker">Posts</p>
            <h2 class="lead-title">{{ site.postsPageIntroTitle }}</h2>
            <p class="lead-copy">{{ site.postsPageIntroText }}</p>
        </section>

        <div class="posts-filters posts-filters-archive posts-filters-archive-bordered" aria-label="Post filters">
            <label class="posts-filter-inline">
                <span class="posts-filter-label">Category</span>
                <select class="posts-filter-select" data-filter-group="category" aria-label="Filter posts by category"></select>
            </label>
            <label class="posts-filter-inline">
                <span class="posts-filter-label">Subcategory</span>
                <select class="posts-filter-select" data-filter-group="subcategory" aria-label="Filter posts by subcategory"></select>
            </label>
            <label class="posts-filter-inline">
                <span class="posts-filter-label">Kind</span>
                <select class="posts-filter-select" data-filter-group="kind" aria-label="Filter posts by kind"></select>
            </label>
        </div>

        <section class="content-section content-section-archive">
            <div class="list-stream">
                {% for post in collections.postsDesc %}
                    <article class="stream-item post-item"
                             data-category="{{ post.data.category }}"
                             data-subcategory="{{ post.data.subcategory }}"
                             data-kind="{{ post.data.kind or '' }}">
                        <div class="stream-copy">
                            <div class="stream-meta">
                                <span class="stream-topic">{{ post.data.category }}</span>
                                <span class="stream-subtopic">{{ post.data.subcategory }}</span>
                                <span class="stream-date">{{ post.date | displayDate }}</span>
                            </div>
                            <h3 class="stream-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                            <p class="stream-excerpt">{{ post.data.excerpt }}</p>
                            <div class="stream-actions">
                                <a href="{{ post.url }}" class="text-link">Read post</a>
                            </div>
                        </div>
                        <a href="{{ post.url }}" class="stream-preview{% if post.data.imageFit == 'contain' %} stream-preview-contain{% endif %}" aria-label="Open {{ post.data.title }}">
                            <img src="{{ post.data.image }}" alt="{{ post.data.title }}" class="stream-preview-image">
                        </a>
                    </article>
                {% endfor %}
            </div>
        </section>

        <footer class="site-footer">
            <p>{{ site.footerText }}</p>
            <p>&copy; 2026 {{ site.name }}</p>
        </footer>
    </main>
</div>
<script>
    (() => {
        const posts = Array.from(document.querySelectorAll(".post-item"));
        if (!posts.length) return;

        const groups = ["category", "subcategory", "kind"];
        const state = Object.fromEntries(groups.map((group) => [group, "all"]));
        const selects = Object.fromEntries(
            groups.map((group) => [group, document.querySelector(`[data-filter-group="${group}"]`)])
        );
        const allValues = Object.fromEntries(
            groups.map((group) => [
                group,
                Array.from(new Set(posts.map((post) => post.dataset[group]).filter(Boolean))).sort(),
            ])
        );

        const acronymMap = {
            ai: "AI",
            rag: "RAG",
            aws: "AWS",
            api: "API",
            apis: "APIs",
            db: "DB",
            llm: "LLM",
            gpu: "GPU",
            hpc: "HPC",
        };

        const formatLabel = (value) =>
            value
                .split(/([\s/-]+)/)
                .map((part) => acronymMap[part] || (part.charAt(0).toUpperCase() + part.slice(1)))
                .join("");

        const setOptions = (group, values) => {
            const select = selects[group];
            if (!select) return;
            const options = ["all", ...values];
            select.innerHTML = "";

            options.forEach((value) => {
                const option = document.createElement("option");
                option.value = value;
                option.textContent = value === "all" ? "All" : formatLabel(value);
                select.appendChild(option);
            });
        };

        const renderGroup = (group) => {
            const select = selects[group];
            if (!select) return;
            setOptions(group, allValues[group]);
            select.value = "all";
            select.addEventListener("change", () => {
                state[group] = select.value;
                update();
            });
        };

        const availableValues = (group) => {
            return Array.from(
                new Set(
                    posts
                        .filter((post) =>
                            groups.every((candidate) =>
                                candidate === group || state[candidate] === "all" || post.dataset[candidate] === state[candidate]
                            )
                        )
                        .map((post) => post.dataset[group])
                        .filter(Boolean)
                )
            ).sort();
        };

        const update = () => {
            groups.forEach((group) => {
                const values = availableValues(group);
                const current = state[group];
                setOptions(group, values);
                if (current !== "all" && !values.includes(current)) {
                    state[group] = "all";
                }
                selects[group].value = state[group];
            });

            posts.forEach((post) => {
                const matches = groups.every((group) => state[group] === "all" || post.dataset[group] === state[group]);
                post.hidden = !matches;
                post.classList.remove("post-item-first-visible");
            });

            const firstVisible = posts.find((post) => !post.hidden);
            if (firstVisible) {
                firstVisible.classList.add("post-item-first-visible");
            }
        };

        groups.forEach(renderGroup);
        update();
    })();
</script>
