---
layout: layouts/base.njk
title: About Me
description: About Me page for Alan Wang.
navKey: about
pageShellClass: about-layout
permalink: /about.html
---
<div class="layout-grid">
    <aside class="identity-rail">
        <div class="identity-block">
            <p class="eyebrow">Applied AI Engineer</p>
            <h1 class="identity-title">{{ site.name }}</h1>
            <p class="identity-summary">{{ site.tagline }}</p>
        </div>

        <div class="identity-meta">
            {% for fact in site.quickFacts %}
                <span class="meta-pill">{{ fact }}</span>
            {% endfor %}
        </div>
    </aside>

    <main class="content-column">
        <section class="about-hero lead-panel">
            <p class="section-kicker">About Me</p>
            <h2 class="about-title">{{ site.about.headline }}</h2>
            <p class="about-hero-note">Backend, cloud, and applied AI.</p>
        </section>

        <section class="about-panel">
            <p class="about-copy">{{ site.about.intro }}</p>
            <p class="about-copy">{{ site.about.shortBio }}</p>
            {% if site.about.quote %}
                <p class="pull-quote">{{ site.about.quote }}</p>
            {% endif %}
        </section>

        <section class="content-section">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Work Experience</p>
                    <h2 class="section-title">Professional Experience.</h2>
                </div>
            </div>

            <div class="about-list">
                {% for item in site.about.experience %}
                    <article class="about-list-item">
                        <div class="about-list-header">
                            <div>
                                <h3 class="about-list-title">{{ item.role }}</h3>
                                <p class="about-list-subtitle">{{ item.organization }}</p>
                            </div>
                            <p class="about-list-period">{{ item.period }}</p>
                        </div>
                        <ul class="about-list-points">
                            {% for point in item.points %}
                                <li>{{ point | safe }}</li>
                            {% endfor %}
                        </ul>
                    </article>
                {% endfor %}
            </div>
        </section>

        {% if site.about.projects %}
            <section class="content-section">
                <div class="section-heading">
                    <div>
                        <p class="section-kicker">Projects</p>
                        <h2 class="section-title">Product work.</h2>
                    </div>
                </div>

                <div class="about-list">
                    {% for item in site.about.projects %}
                        <article class="about-list-item project-list-item">
                            <div class="about-list-header">
                                <div>
                                    <h3 class="about-list-title">{{ item.name }}</h3>
                                    <p class="about-list-subtitle">{{ item.type }}</p>
                                </div>
                                <div class="project-header-meta">
                                    {% if item.period %}
                                        <p class="about-list-period">{{ item.period }}</p>
                                    {% endif %}
                                    {% if item.url %}
                                        <a href="{{ item.url }}" target="_blank" rel="noreferrer" class="project-url">Visit website</a>
                                    {% endif %}
                                </div>
                            </div>
                            {% if item.summary %}
                                <p class="project-summary">{{ item.summary | safe }}</p>
                            {% endif %}
                            {% if item.details %}
                                <div class="project-details" data-project-details>
                                    <div class="project-details-body" id="project-details-{{ loop.index }}" data-project-details-body>
                                        {% for paragraph in item.details %}
                                            <p>{{ paragraph | safe }}</p>
                                        {% endfor %}
                                    </div>
                                    <button class="project-details-toggle" type="button" aria-expanded="false" aria-controls="project-details-{{ loop.index }}" data-project-details-toggle>Read more</button>
                                </div>
                            {% endif %}
                        </article>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        <section class="content-section">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Education</p>
                    <h2 class="section-title">Academic background.</h2>
                </div>
            </div>

            <div class="about-list">
                {% for item in site.about.education %}
                    <article class="about-list-item">
                        <div class="about-list-header">
                            <div>
                                <h3 class="about-list-title">{{ item.degree }}</h3>
                                <p class="about-list-subtitle">{{ item.school }}</p>
                            </div>
                            <p class="about-list-period">{{ item.period }}</p>
                        </div>
                    </article>
                {% endfor %}
            </div>
        </section>

        <section id="contact" class="content-section">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">Contact</p>
                    <h2 class="section-title">Contact</h2>
                </div>
            </div>

            <div class="contact-panel">
                <p class="contact-copy">{{ site.contact.blurb }}</p>
                <div class="contact-links">
                    {% for link in site.contact.links %}
                        <a href="{{ link.url }}"
                           {% if link.external %}target="_blank" rel="noreferrer"{% endif %}
                           class="contact-link">
                            {{ link.label }}
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>

        <footer class="site-footer">
            <p>{{ site.footerText }}</p>
            <p>&copy; 2026 {{ site.name }}</p>
        </footer>
    </main>
</div>

<script>
    document.querySelectorAll("[data-project-details]").forEach((details) => {
        const body = details.querySelector("[data-project-details-body]");
        const toggle = details.querySelector("[data-project-details-toggle]");
        if (!body || !toggle) return;

        toggle.addEventListener("click", () => {
            const isExpanded = details.classList.toggle("is-expanded");
            toggle.setAttribute("aria-expanded", String(isExpanded));
            toggle.textContent = isExpanded ? "Show less" : "Read more";
        });
    });
</script>
